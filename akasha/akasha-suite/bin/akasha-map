#!/usr/bin/env python3
from pathlib import Path

HOME = Path.home()

# Find repos - check both ~/akasha-* and ~/akasha/akasha-*
repos = sorted(
    p for p in HOME.iterdir()
    if p.is_dir() and p.name.startswith("akasha-")
)

akasha_dir = HOME / "akasha"
if akasha_dir.exists() and akasha_dir.is_dir():
    nested = sorted(
        p for p in akasha_dir.iterdir()
        if p.is_dir() and p.name.startswith("akasha-")
    )
    if len(nested) > len(repos):
        repos = nested

print("\nAKASHA CONSTELLATION MAP\n")
for r in repos:
    print("-", r.name)
print("\nTotal Akasha repos:", len(repos), "\n")
